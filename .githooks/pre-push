#!/usr/bin/env bash
# Gates pushes to origin behind the full local test suite (scripts/test-all.sh).
# Installed via `git config core.hooksPath .githooks` (the npm prepare script
# does this on install). Emergency bypass: git push --no-verify

set -euo pipefail

remote="${1:-}"
[ "$remote" = "origin" ] || exit 0

zero=0000000000000000000000000000000000000000
pushing_commits=0
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  [ "$local_sha" = "$zero" ] || pushing_commits=1
done
[ "$pushing_commits" -eq 1 ] || exit 0

echo "pre-push: running the full test suite before pushing to origin"
echo "pre-push: (bypass in an emergency with: git push --no-verify)"
bash "$(git rev-parse --show-toplevel)/scripts/test-all.sh"
