# Postgres (Supabase-hosted in prod; any Postgres for local dev)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tabula

# Supabase project URL — used to fetch the JWKS for JWT verification
SUPABASE_URL=https://your-project.supabase.co

# Comma-separated list of allowed browser origins
CORS_ALLOWED_ORIGIN=http://localhost:5173

# HTTP port (default 8080)
PORT=8080

# Directory of *.wasm plugin components loaded at boot (default plugins/dist)
PLUGIN_DIR=plugins/dist

# Snapshot cadence: write a snapshot every N records (default 200)
SNAPSHOT_EVERY=200

# Optional: OTLP trace export endpoint (e.g. http://alloy:4317)
# OTEL_EXPORTER_OTLP_ENDPOINT=
